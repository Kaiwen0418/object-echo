# Enable remote-backed integration tests
RUN_REMOTE_INTEGRATION=false

# By default, the integration suite can reuse the same Supabase project
# settings as your normal local app config. If these are already defined in
# `.env.local`, you can leave the integration-specific variants blank.
#
# INTEGRATION_SUPABASE_URL=
# INTEGRATION_SUPABASE_ANON_KEY=
# INTEGRATION_SUPABASE_SERVICE_ROLE_KEY=

# Required for integration tests:
# use a dedicated user that exists in the remote test Supabase project.
INTEGRATION_SUPABASE_TEST_EMAIL=
INTEGRATION_SUPABASE_TEST_PASSWORD=
